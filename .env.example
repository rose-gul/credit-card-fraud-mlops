# Copy to `.env` and adjust. Never commit the real .env (it is gitignored).
# All app settings use the FRAUD_ prefix.

# MLflow tracking store (defaults to the local ./mlruns file store).
# FRAUD_MLFLOW_TRACKING_URI=file:///./mlruns

# Path to the model bundle the serving API loads.
FRAUD_MODEL_PATH=models/model_xgb.json

# Your Kaggle username (also read from ~/.kaggle/kaggle.json if omitted).
# FRAUD_KAGGLE_USERNAME=gulhanimsc

# Optional serving threshold overrides (else taken from params.yaml).
# FRAUD_APPROVE_BELOW=0.30
# FRAUD_BLOCK_ABOVE=0.85

# --- Kaggle API credentials ---
# The kaggle CLI reads ~/.kaggle/kaggle.json automatically. Alternatively set:
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key
